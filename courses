<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Léman Courses – Calculateur Express</title>
  <meta name="description" content="Mini-app Léman Courses : estimation rapide et prise de contact en 1 clic." />

  <style>
    :root{
      --blue:#0f2f5f;
      --blue2:#163c77;
      --yellow:#f7b500;
      --bg:#f5f7fb;
      --text:#0b1220;
      --muted:#5b6576;
      --card:#ffffff;
      --stroke:#e6eaf2;
      --shadow: 0 10px 25px rgba(15,47,95,.12);
      --radius:18px;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji","Segoe UI Emoji";
      background: radial-gradient(1200px 600px at 20% 0%, rgba(247,181,0,.18), transparent 60%),
                  radial-gradient(1000px 600px at 90% 20%, rgba(15,47,95,.18), transparent 55%),
                  var(--bg);
      color:var(--text);
    }
    .wrap{max-width:980px; margin:0 auto; padding:22px 16px 34px;}
    .topbar{
      display:flex; gap:14px; align-items:center; justify-content:space-between;
      background: linear-gradient(135deg, var(--blue), var(--blue2));
      color:#fff; border-radius: var(--radius);
      padding:16px 16px;
      box-shadow: var(--shadow);
      overflow:hidden;
      position:relative;
    }
    .topbar:after{
      content:"";
      position:absolute;
      right:-80px; top:-80px;
      width:220px; height:220px;
      border-radius:50%;
      background: radial-gradient(circle at 40% 40%, rgba(247,181,0,.45), rgba(247,181,0,0) 60%);
      filter: blur(0px);
    }
    .brand{
      display:flex; gap:12px; align-items:center;
      min-width: 240px;
    }
    .logo{
      width:52px; height:52px; border-radius:14px;
      background: rgba(255,255,255,.12);
      display:grid; place-items:center;
      border:1px solid rgba(255,255,255,.20);
      overflow:hidden;
    }
    .logo img{width:100%; height:100%; object-fit:cover; display:none;}
    .brand h1{font-size:18px; margin:0; letter-spacing:.2px}
    .brand p{margin:2px 0 0; font-size:12px; opacity:.9}
    .pill{
      display:flex; gap:8px; flex-wrap:wrap; justify-content:flex-end;
    }
    .pill span{
      font-size:12px;
      padding:8px 10px;
      border-radius:999px;
      background: rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.18);
      white-space:nowrap;
    }

    .grid{
      margin-top:14px;
      display:grid;
      grid-template-columns: 1.1fr .9fr;
      gap:14px;
    }
    @media (max-width: 860px){
      .grid{grid-template-columns:1fr}
      .pill{justify-content:flex-start}
      .brand{min-width:auto}
    }

    .card{
      background:var(--card);
      border:1px solid var(--stroke);
      border-radius: var(--radius);
      box-shadow: 0 10px 25px rgba(2,8,23,.06);
      padding:16px;
    }
    .card h2{
      font-size:16px; margin:0 0 10px;
      display:flex; align-items:center; gap:8px;
    }
    .sub{color:var(--muted); font-size:13px; margin:6px 0 0; line-height:1.35}
    .row{display:grid; gap:12px; margin-top:12px}
    .group{
      border:1px solid var(--stroke);
      border-radius:16px;
      padding:12px;
      background: #fbfcff;
    }
    .group-title{
      display:flex; align-items:center; justify-content:space-between;
      gap:10px; margin-bottom:10px;
    }
    .group-title b{font-size:13px}
    .group-title small{color:var(--muted)}
    .opts{display:grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap:10px;}
    @media (max-width:520px){ .opts{grid-template-columns:1fr} }
    label.opt{
      display:flex; align-items:center; gap:10px;
      border:1px solid var(--stroke);
      border-radius:14px;
      padding:12px 12px;
      background:#fff;
      cursor:pointer;
      transition: transform .08s ease, border-color .15s ease, box-shadow .15s ease;
      user-select:none;
    }
    label.opt:hover{transform: translateY(-1px); border-color:#d7deeb; box-shadow: 0 10px 18px rgba(2,8,23,.06);}
    label.opt input{accent-color: var(--yellow); transform: scale(1.1);}
    .opt .txt{display:flex; flex-direction:column; line-height:1.15}
    .opt .txt strong{font-size:13px}
    .opt .txt span{font-size:12px; color:var(--muted)}
    .badge{
      margin-left:auto;
      font-size:12px;
      font-weight:700;
      color:var(--blue);
      background: rgba(247,181,0,.22);
      border:1px solid rgba(247,181,0,.35);
      padding:6px 8px;
      border-radius:999px;
      white-space:nowrap;
    }

    .result{
      display:flex; flex-direction:column; gap:10px;
    }
    .hero{
      border-radius: 18px;
      overflow:hidden;
      border:1px solid var(--stroke);
      background: linear-gradient(135deg, rgba(15,47,95,.06), rgba(247,181,0,.10));
      min-height: 210px;
      position:relative;
    }
    .hero img{
      width:100%; height:100%;
      object-fit:cover;
      display:none;
    }
    .hero .fallback{
      position:absolute; inset:0;
      display:grid; place-items:center;
      padding:14px;
      text-align:center;
      color:var(--blue);
    }
    .hero .fallback b{font-size:16px}
    .hero .fallback span{display:block; margin-top:6px; color:var(--muted); font-size:13px}
    .pricebox{
      background: linear-gradient(135deg, var(--blue), var(--blue2));
      color:#fff;
      border-radius: 18px;
      padding:14px 14px;
      box-shadow: var(--shadow);
      border: 1px solid rgba(255,255,255,.18);
    }
    .pricebox .line1{display:flex; align-items:baseline; justify-content:space-between; gap:10px;}
    .pricebox .line1 b{font-size:14px; letter-spacing:.2px}
    .pricebox .big{font-size:30px; font-weight:900; letter-spacing:.2px}
    .pricebox .note{margin-top:6px; font-size:12px; opacity:.9}

    .actions{
      display:grid; grid-template-columns: 1fr;
      gap:10px;
      margin-top:10px;
    }
    .btn{
      width:100%;
      border:0;
      border-radius: 14px;
      padding:12px 14px;
      font-weight:800;
      cursor:pointer;
      display:flex; align-items:center; justify-content:center; gap:10px;
      text-decoration:none;
      transition: transform .08s ease, filter .12s ease;
    }
    .btn:hover{transform: translateY(-1px); filter: brightness(1.03);}
    .btn-call{background: var(--yellow); color: #1a1a1a;}
    .btn-wa{background: #0f2f5f; color:#fff;}
    .btn-mail{background: #ffffff; color: var(--blue); border:1px solid var(--stroke);}

    .phone-script{
      margin-top:10px;
      border-radius: 16px;
      border:1px dashed #d6dced;
      background:#fff;
      padding:12px;
    }
    .phone-script b{display:block; font-size:13px; margin-bottom:6px}
    .phone-script p{margin:0; color:var(--muted); font-size:13px; line-height:1.35}

    .footer{
      margin-top:12px;
      color:var(--muted);
      font-size:12px;
      text-align:center;
    }
    .tiny{
      font-size:11px;
      color:var(--muted);
    }
  </style>
</head>

<body>
  <div class="wrap">
    <header class="topbar">
      <div class="brand">
        <div class="logo" title="Logo Léman Courses">
          <!-- Mets ton logo ici : remplace le src par un fichier local (logo.png) ou une URL -->
          <img id="logoImg" alt="Logo Léman Courses" />
          <svg id="logoSvg" width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M4 13.5l3-3 3 3 7-7" stroke="rgba(255,255,255,.95)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M20 6.5v5h-5" stroke="rgba(255,255,255,.95)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <h1>LÉMAN COURSES</h1>
          <p>Calculateur express • Vaud • Genève • Neuchâtel</p>
        </div>
      </div>
      <div class="pill">
        <span>📞 +41 79 870 04 88</span>
        <span>🕒 24h/24 • 7j/7</span>
        <span>🔒 Direct & confidentiel</span>
      </div>
    </header>

    <main class="grid">
      <!-- LEFT -->
      <section class="card">
        <h2>⚡ Estimez votre course</h2>
        <p class="sub">Sélectionnez 3 options. Le tarif affiché est <b>“dès”</b> (confirmé avant la course).</p>

        <div class="row">
          <div class="group">
            <div class="group-title">
              <b>1) Type de course</b>
              <small>Base</small>
            </div>
            <div class="opts">
              <label class="opt">
                <input type="radio" name="type" value="local" checked>
                <div class="txt">
                  <strong>Locale</strong>
                  <span>Même ville / agglomération</span>
                </div>
                <span class="badge">dès 35.–</span>
              </label>

              <label class="opt">
                <input type="radio" name="type" value="inter">
                <div class="txt">
                  <strong>Inter-villes</strong>
                  <span>VD / GE / NE</span>
                </div>
                <span class="badge">dès 65.–</span>
              </label>

              <label class="opt">
                <input type="radio" name="type" value="surdemande">
                <div class="txt">
                  <strong>Suisse entière</strong>
                  <span>Sur demande</span>
                </div>
                <span class="badge">sur devis</span>
              </label>
            </div>
            <p class="tiny" style="margin:10px 0 0;">
              Option “Suisse entière” affiche une estimation indicative (à confirmer au téléphone).
            </p>
          </div>

          <div class="group">
            <div class="group-title">
              <b>2) Urgence</b>
              <small>Priorité</small>
            </div>
            <div class="opts">
              <label class="opt">
                <input type="radio" name="urgence" value="standard" checked>
                <div class="txt">
                  <strong>Standard</strong>
                  <span>≤ 4–6h</span>
                </div>
                <span class="badge">+0</span>
              </label>

              <label class="opt">
                <input type="radio" name="urgence" value="urgent">
                <div class="txt">
                  <strong>Urgente</strong>
                  <span>≤ 2–3h</span>
                </div>
                <span class="badge">+10</span>
              </label>

              <label class="opt">
                <input type="radio" name="urgence" value="express">
                <div class="txt">
                  <strong>Express</strong>
                  <span>Direct</span>
                </div>
                <span class="badge">+25</span>
              </label>
            </div>
          </div>

          <div class="group">
            <div class="group-title">
              <b>3) Horaire</b>
              <small>Majoration</small>
            </div>
            <div class="opts">
              <label class="opt">
                <input type="radio" name="horaire" value="jour" checked>
                <div class="txt">
                  <strong>Jour</strong>
                  <span>06h–20h</span>
                </div>
                <span class="badge">0%</span>
              </label>

              <label class="opt">
                <input type="radio" name="horaire" value="nuit">
                <div class="txt">
                  <strong>Nuit</strong>
                  <span>20h–06h</span>
                </div>
                <span class="badge">+25%</span>
              </label>

              <label class="opt">
                <input type="radio" name="horaire" value="dimanche">
                <div class="txt">
                  <strong>Dimanche / férié</strong>
                  <span>Prioritaire</span>
                </div>
                <span class="badge">+30%</span>
              </label>
            </div>
          </div>

        </div>
      </section>

      <!-- RIGHT -->
      <aside class="card result">
        <h2>✅ Résultat</h2>

        <div class="hero">
          <!-- Mets ta photo voiture ici : remplace le src par un fichier local (voiture.png) ou une URL -->
          <img id="carImg" alt="Voiture Léman Courses" />
          <div class="fallback" id="carFallback">
            <div>
              <b>Ajoute la photo de ta voiture</b>
              <span>Remplace <code>voiture.png</code> dans le code (voir instructions en bas).</span>
            </div>
          </div>
        </div>

        <div class="pricebox" aria-live="polite">
          <div class="line1">
            <b>Tarif estimatif</b>
            <span class="big" id="price">dès CHF 35.–</span>
          </div>
          <div class="note" id="summary">Locale • Standard • Jour</div>
          <div class="note">Tarif indicatif – confirmé avant la course.</div>
        </div>

        <div class="actions">
          <a class="btn btn-call" id="callBtn" href="tel:+41798700488">📞 Appeler maintenant</a>
          <a class="btn btn-wa" id="waBtn" href="#" target="_blank" rel="noopener">💬 WhatsApp (message)</a>
          <a class="btn btn-mail" id="mailBtn" href="#">✉️ Demande par e-mail</a>
        </div>

        <div class="phone-script">
          <b>📞 Réponse rapide (téléphone)</b>
          <p>
            « Les tarifs commencent <b>dès 35 francs</b>. Le prix dépend de l’urgence, de la distance et de l’horaire.
            Je peux vous confirmer le montant immédiatement avec les adresses. »
          </p>
        </div>

        <div class="footer">
          LÉMAN COURSES • +41 79 870 04 88 • info@leman-courses.ch • leman-courses.ch
        </div>
      </aside>
    </main>

    <div class="card" style="margin-top:14px;">
      <h2>🧩 Comment mettre ton logo & ta voiture</h2>
      <p class="sub">
        1) Mets ce fichier en <b>index.html</b><br>
        2) Place deux images dans le même dossier : <b>logo.png</b> et <b>voiture.png</b><br>
        3) L’app les chargera automatiquement.
      </p>
      <p class="tiny" style="margin:10px 0 0;">
        Astuce : si tu n’héberges pas encore, tu peux l’ouvrir localement (double-clic) ou l’envoyer sur un hébergeur simple.
      </p>
    </div>

  </div>

  <script>
    // ==== CONFIG CONTACT (modifie ici si besoin) ====
    const PHONE = "+41798700488";
    const EMAIL = "info@leman-courses.ch";
    const SITE  = "https://www.leman-courses.ch"; // optionnel
    const WA_NUMBER = "41798700488"; // sans +

    // ==== PRIX (grille "dès") ====
    const baseByType = {
      local: 35,
      inter: 65,
      surdemande: 85 // estimation indicative (Suisse entière)
    };

    const addByUrgence = {
      standard: 0,
      urgent: 10,
      express: 25
    };

    const multByHoraire = {
      jour: 1.00,
      nuit: 1.25,
      dimanche: 1.30
    };

    const label = {
      type: {
        local: "Locale",
        inter: "Inter-villes",
        surdemande: "Suisse entière"
      },
      urgence: {
        standard: "Standard",
        urgent: "Urgente",
        express: "Express"
      },
      horaire: {
        jour: "Jour",
        nuit: "Nuit",
        dimanche: "Dimanche / férié"
      }
    };

    // ==== UI refs ====
    const priceEl = document.getElementById("price");
    const summaryEl = document.getElementById("summary");
    const waBtn = document.getElementById("waBtn");
    const mailBtn = document.getElementById("mailBtn");
    const callBtn = document.getElementById("callBtn");

    // ==== Auto-load local images if present ====
    const logoImg = document.getElementById("logoImg");
    const logoSvg = document.getElementById("logoSvg");
    const carImg = document.getElementById("carImg");
    const carFallback = document.getElementById("carFallback");

    function tryLoad(imgEl, fallbackEl, src, onOk){
      imgEl.onload = () => { imgEl.style.display="block"; if(fallbackEl) fallbackEl.style.display="none"; onOk && onOk(); };
      imgEl.onerror = () => { /* keep fallback */ };
      imgEl.src = src;
    }

    tryLoad(logoImg, null, "logo.png", () => { logoSvg.style.display="none"; });
    tryLoad(carImg, carFallback, "voiture.png");

    // ==== Helpers ====
    function getValue(name){
      const el = document.querySelector(`input[name="${name}"]:checked`);
      return el ? el.value : null;
    }

    function formatCHF(n){
      // n is number
      const rounded = Math.round(n);
      return `dès CHF ${rounded}.–`;
    }

    function buildMessage(sel){
      return `Bonjour, je souhaite une course ${label.urgence[sel.urgence]} (${label.type[sel.type]}) en horaire ${label.horaire[sel.horaire]}. ` +
             `Pouvez-vous me confirmer le prix et la disponibilité ? Merci.`;
    }

    function update(){
      const sel = {
        type: getValue("type"),
        urgence: getValue("urgence"),
        horaire: getValue("horaire")
      };

      const base = baseByType[sel.type] ?? 35;
      const add  = addByUrgence[sel.urgence] ?? 0;
      const mult = multByHoraire[sel.horaire] ?? 1;

      const estimated = (base + add) * mult;

      priceEl.textContent = formatCHF(estimated);
      summaryEl.textContent = `${label.type[sel.type]} • ${label.urgence[sel.urgence]} • ${label.horaire[sel.horaire]}`;

      const msg = buildMessage(sel);
      const waUrl = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`;
      waBtn.href = waUrl;

      const mailSubject = `Demande de course – ${label.urgence[sel.urgence]} – ${label.type[sel.type]}`;
      const mailBody =
        `${msg}\n\n` +
        `Départ : \nArrivée : \nDate/heure : \nPoids/colis : \n\n` +
        `Lien : ${SITE}\n`;

      mailBtn.href = `mailto:${EMAIL}?subject=${encodeURIComponent(mailSubject)}&body=${encodeURIComponent(mailBody)}`;

      callBtn.href = `tel:${PHONE}`;
    }

    document.querySelectorAll('input[type="radio"]').forEach(r => {
      r.addEventListener("change", update);
    });

    update();
  </script>
</body>
</html>
