<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Découvrez tous les services de transport express Colixo : livraison express, suivi GPS, solutions entreprises et plus.">
    <title>Nos Services — Colixo Transport Express</title>
    <link rel="icon" type="image/svg+xml" href="favicon.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --red:       #e8311a;
            --red-dark:  #c0280f;
            --red-glow:  rgba(232,49,26,0.22);
            --night:     #0a0a0f;
            --night2:    #111118;
            --night3:    #18181f;
            --surface:   #1e1e28;
            --border:    rgba(255,255,255,0.07);
            --border2:   rgba(255,255,255,0.12);
            --white:     #ffffff;
            --muted:     rgba(255,255,255,0.38);
            --muted2:    rgba(255,255,255,0.6);
            --green:     #22c55e;
            --blue:      #3b82f6;
            --amber:     #f59e0b;
        }
        *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; }
        body {
            font-family: 'Outfit', sans-serif;
            background: var(--night);
            color: var(--white);
            overflow-x: hidden;
        }

        /* ── Nav ── */
        nav {
            position:fixed; top:0; left:0; right:0; z-index:400;
            padding:22px 60px;
            display:flex; align-items:center; justify-content:space-between;
            background:rgba(10,10,15,0.92);
            backdrop-filter:blur(20px);
            border-bottom:1px solid var(--border);
        }
        .logo {
            display:flex; align-items:center; gap:12px;
            font-family:'Bebas Neue', cursive;
            font-size:26px; letter-spacing:1px;
            color:var(--white); text-decoration:none;
        }
        .logo-mark {
            width:38px; height:38px; background:var(--red);
            border-radius:10px; display:grid; place-items:center;
            font-size:18px; transition:transform 0.3s;
        }
        .logo:hover .logo-mark { transform:rotate(-10deg) scale(1.1); }
        .logo em { color:var(--red); font-style:normal; }
        .nav-links {
            display:flex; gap:32px; align-items:center;
        }
        .nav-links a {
            color:var(--muted2); text-decoration:none;
            font-size:14px; font-weight:500;
            transition:color 0.2s;
        }
        .nav-links a:hover, .nav-links a.active {
            color:var(--red);
        }
        .btn {
            font-family:'Outfit', sans-serif; font-weight:600; font-size:14px;
            padding:11px 26px; border-radius:100px; border:none;
            cursor:pointer; display:inline-flex; align-items:center; gap:8px;
            transition:all 0.25s; white-space:nowrap; text-decoration:none;
        }
        .btn-red {
            background:var(--red); color:var(--white);
            box-shadow:0 4px 20px var(--red-glow);
        }
        .btn-red:hover { 
            background:var(--red-dark); 
            transform:translateY(-2px); 
            box-shadow:0 8px 32px var(--red-glow); 
        }

        /* ── Hero ── */
        .page-hero {
            padding:140px 60px 80px;
            text-align:center;
            background:linear-gradient(180deg, var(--night2) 0%, var(--night) 100%);
            border-bottom:1px solid var(--border);
            position:relative;
            overflow:hidden;
        }
        .page-hero::before {
            content:''; position:absolute; inset:0;
            background-image:
                linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
            background-size:60px 60px;
        }
        .breadcrumb {
            font-size:13px; color:var(--muted);
            margin-bottom:24px;
        }
        .breadcrumb a {
            color:var(--red); text-decoration:none;
        }
        .breadcrumb a:hover { text-decoration:underline; }
        .page-title {
            font-family:'Bebas Neue', cursive;
            font-size:clamp(56px, 7vw, 96px);
            line-height:0.95; letter-spacing:2px;
            color:var(--white); margin-bottom:24px;
        }
        .page-title .accent { color:var(--red); }
        .page-subtitle {
            font-size:18px; color:var(--muted2);
            max-width:680px; margin:0 auto 40px;
            line-height:1.6; font-weight:300;
        }

        /* ── Services détaillés ── */
        .services-detailed {
            padding:100px 60px;
        }
        .service-card {
            background:var(--night2);
            border:1px solid var(--border2);
            border-radius:28px;
            padding:60px;
            margin-bottom:40px;
            display:grid;
            grid-template-columns:120px 1fr;
            gap:50px;
            align-items:start;
            transition:all 0.3s;
            position:relative;
            overflow:hidden;
        }
        .service-card::before {
            content:''; position:absolute;
            top:-100px; right:-100px;
            width:300px; height:300px;
            background:var(--red);
            border-radius:50%;
            opacity:0;
            transition:opacity 0.4s;
        }
        .service-card:hover {
            background:var(--night3);
            border-color:var(--border);
            transform:translateY(-4px);
        }
        .service-card:hover::before { opacity:0.04; }
        .service-icon-big {
            width:120px; height:120px;
            background:var(--surface);
            border-radius:20px;
            display:grid; place-items:center;
            font-size:48px;
            position:relative;
            z-index:1;
        }
        .service-content h2 {
            font-family:'Bebas Neue', cursive;
            font-size:42px; letter-spacing:1px;
            color:var(--white);
            margin-bottom:16px;
        }
        .service-content p {
            font-size:16px; color:var(--muted2);
            line-height:1.7; margin-bottom:32px;
            font-weight:300;
        }
        .service-features {
            display:grid;
            grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));
            gap:24px;
            margin-bottom:32px;
        }
        .feature-item {
            display:flex; align-items:start; gap:14px;
            padding:18px;
            background:var(--surface);
            border-radius:14px;
            border:1px solid var(--border);
        }
        .feature-icon {
            width:40px; height:40px;
            background:rgba(232,49,26,0.1);
            border-radius:10px;
            display:grid; place-items:center;
            color:var(--red);
            flex-shrink:0;
        }
        .feature-text h4 {
            font-size:15px; font-weight:600;
            color:var(--white);
            margin-bottom:6px;
        }
        .feature-text p {
            font-size:13px; color:var(--muted);
            line-height:1.6; margin:0;
        }
        .service-pricing {
            display:flex; align-items:center;
            justify-content:space-between;
            padding-top:32px;
            border-top:1px solid var(--border);
            flex-wrap:wrap;
            gap:20px;
        }
        .price-tag {
            font-family:'Bebas Neue', cursive;
            font-size:36px; letter-spacing:1px;
            color:var(--white);
        }
        .price-tag small {
            font-family:'Outfit', sans-serif;
            font-size:14px; color:var(--muted);
            font-weight:400;
        }
        .service-cta {
            display:flex; gap:12px; flex-wrap:wrap;
        }

        /* ── Zones ── */
        .zones-section {
            padding:80px 60px;
            background:var(--night2);
            border-top:1px solid var(--border);
        }
        .zones-title {
            font-family:'Bebas Neue', cursive;
            font-size:48px; letter-spacing:1px;
            text-align:center;
            margin-bottom:48px;
        }
        .zones-grid {
            display:grid;
            grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));
            gap:24px;
            max-width:1200px;
            margin:0 auto;
        }
        .zone-card {
            background:var(--night3);
            border:1px solid var(--border2);
            border-radius:18px;
            padding:32px;
            text-align:center;
            transition:all 0.3s;
        }
        .zone-card:hover {
            border-color:var(--red);
            transform:translateY(-4px);
        }
        .zone-icon {
            font-size:36px;
            margin-bottom:16px;
        }
        .zone-name {
            font-family:'Bebas Neue', cursive;
            font-size:24px; letter-spacing:1px;
            color:var(--white);
            margin-bottom:12px;
        }
        .zone-cities {
            font-size:13px; color:var(--muted);
            line-height:1.6;
        }

        /* ── Footer ── */
        footer {
            background:var(--night2);
            border-top:1px solid var(--border);
            padding:36px 60px;
            display:flex;
            align-items:center;
            justify-content:space-between;
            flex-wrap:wrap;
            gap:20px;
        }
        .foot-logo {
            font-family:'Bebas Neue',cursive;
            font-size:20px;
            color:var(--white);
            letter-spacing:1px;
        }
        .foot-logo em { font-style:normal; color:var(--red); }
        .foot-copy { font-size:13px; color:var(--muted); }

        /* ── Responsive ── */
        @media(max-width:768px) {
            nav { padding:16px 20px; }
            .nav-links { display:none; }
            .page-hero { padding:120px 20px 60px; }
            .services-detailed { padding:60px 20px; }
            .service-card {
                grid-template-columns:1fr;
                padding:40px 24px;
                gap:30px;
            }
            .service-icon-big {
                width:80px; height:80px;
                font-size:36px;
            }
            .zones-section { padding:60px 20px; }
            footer { padding:28px 20px; flex-direction:column; }
        }
    </style>
</head>
<body>

